PORT=3001
JWT_SECRET=change_this_secret_in_production
CONSENT_JWT_SECRET=change_this_consent_secret_in_production

# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

DATABASE_PATH=./data/snail.db

# Public URLs (used in QR codes and consent email links)
PUBLIC_URL=http://localhost:3001
USER_PWA_URL=http://localhost:5174

# -- Email / SMTP
# Leave blank to use the console stub (emails logged to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# -- SMS / WhatsApp via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=+15550000000
TWILIO_WHATSAPP_FROM=+15550000000

# -- Telegram
# Create a bot with @BotFather, then put the token here
TELEGRAM_BOT_TOKEN=
